<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude the preferences file that tracks onboarding status so it always shows on a clean reinstall -->
        <exclude domain="sharedpref" path="tradetrack_prefs.xml"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="tradetrack_prefs.xml"/>
    </device-transfer>
</data-extraction-rules>